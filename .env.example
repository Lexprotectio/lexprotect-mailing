# ==============================================================================
# 🔐 LexProtect Mailing Otomasyonu - Çevre Değişkenleri Şablonu
# ==============================================================================

# Gönderim Sağlayıcı Seçimi: 'gmail' veya 'resend'
EMAIL_PROVIDER=resend

# OpenAI API Anahtarı (Metin kişiselleştirme ve niyet analizi için)
OPENAI_API_KEY=<OPENAI_API_KEY>

# B2B Lead Arama ve E-posta Zenginleştirme (Enrichment) Anahtarları
APOLLO_API_KEY=<APOLLO_API_KEY>
HUNTER_API_KEY=<HUNTER_API_KEY>

# Resend API Ayarları (EMAIL_PROVIDER=resend ise zorunlu)
RESEND_API_KEY=<RESEND_API_KEY>
RESEND_FROM_EMAIL=LexProtect Outreach <outreach@yourdomain.com>

# Gmail API Ayarları (EMAIL_PROVIDER=gmail ise zorunlu)
# Merkezi Google OAuth sistemindeki hesap adı: 'outreach' (yani account1) veya 'swc' (yani account2)
GMAIL_OUTREACH_ACCOUNT=outreach

# Google Sheets Entegrasyon Ayarları
# https://docs.google.com/spreadsheets/d/SAYFA_IDSI/edit linkindeki SAYFA_IDSI kısmı
GOOGLE_SHEET_ID=<GOOGLE_SHEET_ID>
GOOGLE_SHEET_NAME=Sheet1

# Bildirim E-posta Adresi (Gelen olumlu dönüşlerde uyarılacağınız e-posta)
NOTIFICATION_EMAIL=<BILDIRIM_ALACAGINIZ_EMAIL_ADRESI>

# Günlük Maksimum Gönderim Limiti (Spam engelleme için)
OUTREACH_LIMIT=50
